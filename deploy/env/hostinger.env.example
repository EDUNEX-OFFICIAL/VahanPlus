# Copy to hostinger.env on the VPS (never commit hostinger.env).
#   cp deploy/env/hostinger.env.example deploy/env/hostinger.env
#
# Shared Postgres (2+ apps, one container, separate databases):
#   SKIP_INFRA=true
#   DATABASE_URL → existing host port (e.g. 5434) + DB name vahan360 or vahanplus (NOT gdms)
#   REDIS_URL → shared Redis with logical DB index, e.g. redis://host.k3s.internal:6379/1
#
# Fresh VPS (no Postgres yet): SKIP_INFRA=false and use docker-compose.infra.prod.yml

POSTGRES_USER=vahanplus
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vahanplus

# Kubernetes app secrets (deploy/scripts/create-k8s-secrets.sh):
DATABASE_URL=postgresql://vahanplus:change-me-strong-password@10.42.0.1:54322/vahanplus
# Internal k3s gateway only — not public IP. WAN blocked by secure-vps.sh.
REDIS_URL=redis://10.42.0.1:6379/0

# Set true when Postgres/Redis already run (Hostinger Docker / shared stack)
# SKIP_INFRA=true
JWT_SECRET=change-me-long-random-jwt-secret

# Helm / GHCR (deploy/scripts/hostinger/deploy.sh):
GHCR_ORG=EDUNEX-OFFICIAL
VAHANPLUS_DOMAIN=exp.vahan360.info
GHCR_USERNAME=EDUNEX-OFFICIAL
# GHCR_TOKEN=ghp_...   # read:packages — put only in hostinger.env on VPS, never commit

# Bootstrap (deploy/scripts/hostinger/bootstrap-k3s.sh):
# LETSENCRYPT_EMAIL=admin@example.com
