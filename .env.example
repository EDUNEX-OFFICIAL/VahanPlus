# Docker Compose project name (container prefix: vahanplus-<service>-1)
COMPOSE_PROJECT_NAME=vahanplus

# Database
DATABASE_URL=postgresql://vahanplus:vahanplus@localhost:5434/vahanplus?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API Express
JWT_SECRET=change-me-in-production
PORT=3001

# Seed admin (packages/db)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=admin123

# Worker
BROWSER_POOL_STUB=true
WORKER_CONCURRENCY=4

# Bihar portal throttle (balanced defaults)
BIHAR_PORTAL_RATE_LIMIT_MAX=2
BIHAR_PORTAL_RATE_LIMIT_DURATION_MS=1000
BIHAR_PORTAL_POST_DELAY_MS=1000
BIHAR_FANOUT_STAGGER_MS=0
BIHAR_FETCH_TIMEOUT_MS=30000
BIHAR_FETCH_RETRIES=3
STORE_RAW_CAPTURE=false

# Bihar ePass scraper (optional daily schedule, Asia/Kolkata)
BIHAR_EPASS_REPORT_URL=https://khanansoft.bihar.gov.in/portal/CitizenRpt/epassreportAllDist.aspx
BIHAR_EPASS_ROW_LIMIT=44
# Deprecated for fanout — use BIHAR_FANOUT_STAGGER_MS (kept as fallback alias)
# BIHAR_EPASS_DETAIL_DELAY_MS=2000
BIHAR_EPASS_SKIP_CHALLAN=false
BIHAR_EPASS_SKIP_CHALLAN_PASS=false
BIHAR_EPASS_SKIP_VEHICLE_STATUS=false
BIHAR_EPASS_SKIP_FANOUT=false
# BIHAR_EPASS_MAX_CONSIGNER_JOBS=4
# BIHAR_EPASS_SCHEDULE_CRON=30 6 * * *
# BIHAR_EPASS_SCHEDULE_TZ=Asia/Kolkata
# BIHAR_MCV_VEHICLE_STATUS_URL=https://khanansoft.bihar.gov.in/portal/MCVReports/MCVReportWiseStatus.aspx

# RC Advance (CRM Vehicle Expiry enrichment)
# mock = read docs/rc_advance_mock_by_vrn.json (default)
# http = call paid API (see docs/ops/rc-advance-crm.md)
RC_ADVANCE_PROVIDER=mock
# RC_ADVANCE_MOCK_FILE=docs/rc_advance_mock_by_vrn.json
# RC_ADVANCE_API_URL=https://vendor.example.com/rc-advance
# RC_ADVANCE_API_KEY=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vahanplus

# Nest API (optional)
NEST_PORT=3002
